# Foras MVP — apps/web — variabili d'ambiente
# Copia in .env.local e compila con i valori reali (già in .gitignore).

# ─── Supabase ────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
NEXT_PUBLIC_SUPABASE_SCHEMA=template

# SERVER ONLY — non NEXT_PUBLIC_, non finisce nel bundle client.
# Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ─── Email prenotazioni (DORMIENTE — OFF di default) ─────────────────────────
# Per attivare: vedi supabase/functions/send-booking-email/README.md

# Imposta a 'true' solo dopo aver completato la checklist di attivazione.
BOOKING_EMAIL_ENABLED=false

# URL della Edge Function Supabase (vuoto finché non deployata).
# Esempio: https://<project-ref>.supabase.co/functions/v1/send-booking-email
SEND_BOOKING_EMAIL_URL=

# Origin del sito pubblico, usato per costruire il link di cancellazione nelle email.
# Esempio: https://bar-example.foras.it
NEXT_PUBLIC_SITE_URL=

# NOTA: RESEND_API_KEY e RESEND_FROM sono secret della Edge Function Supabase,
# NON variabili di apps/web né di Vercel. Non vanno aggiunti qui.
