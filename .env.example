# Copy this file to apps/web/.env.local and apps/admin/.env.local
# Fill in your credentials from: supabase.com → project → Settings → API

# Supabase project URL — found in Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key — found in Settings → API → Project API keys → anon / public
# Safe to expose in the browser; security is enforced by RLS policies, not by hiding this key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PostgreSQL schema for this tenant — "template" during development, "bar_rossi" for a real client
NEXT_PUBLIC_SUPABASE_SCHEMA=template

# Supabase service_role key — Settings → API → Project API keys → service_role
# SERVER ONLY — non esporre, non NEXT_PUBLIC_, mai nel bundle client.
# Usata solo da apps/admin per verificare owner in public.tenants prima di aprire un client tenant.
SUPABASE_SERVICE_ROLE_KEY=

# Endpoint HTTP del container supabase-meta usato dallo script `pnpm --filter @repo/supabase gen:types`.
# Solo CLI/dev, non runtime, mai NEXT_PUBLIC_. Lasciare vuoto = default `http://localhost:18080`.
# Richiede tunnel SSH attivo verso il container supabase-meta sulla VPS:
#   ssh -N -L 18080:<IP_CONTAINER_META>:8080 foras-vps
# (recupera IP con: ssh foras-vps "docker inspect supabase-meta --format '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}'")
SUPABASE_META_URL=
