# Copy this file to apps/web/.env.local and apps/admin/.env.local
# Fill in your credentials from: supabase.com → project → Settings → API

# Supabase project URL — found in Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key — found in Settings → API → Project API keys → anon / public
# Safe to expose in the browser; security is enforced by RLS policies, not by hiding this key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PostgreSQL schema for this tenant — "template" during development, "bar_rossi" for a real client
NEXT_PUBLIC_SUPABASE_SCHEMA=template
